{
  "name": "@thefehrs/foundry-playwright",
  "version": "0.1.0",
  "description": "A robust, multi-version E2E testing library for FoundryVTT modules and systems, powered by Playwright.",
  "keywords": [
    "e2e",
    "foundryvtt",
    "playwright",
    "testing"
  ],
  "license": "MIT",
  "author": "TheFehrs",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "foundry-playwright": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "oxlint .",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt .",
    "verify:local": "tsx scripts/verify-local.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "dotenv": "^17.4.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@playwright/test": "^1.40.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
